---
import AnalyticsLayout from '../../../../layouts/AnalyticsLayout.astro';
---

<AnalyticsLayout title="Aquisição">
  
  <div id="loading" class="loading-state">
    <p>Carregando dados de aquisição do Google Analytics...</p>
  </div>

  <div id="dashboard-content" style="display: none;">
    
    <div class="charts-grid">
      <div class="card chart-box">
        <h3>Distribuição por Origem/Mídia</h3>
        <canvas id="sourceMediumChart"></canvas>
      </div>
      
      <div class="card chart-box">
        <h3>Evolução de Tráfego por Canal</h3>
        <canvas id="trendsChart"></canvas>
      </div>
    </div>

    <div class="card mt-20">
      <h3>Desempenho por Canal Padrão</h3>
      <div class="table-responsive mt-10">
        <table id="kpiTable">
          <thead>
            <tr>
              <th>Canal</th>
              <th>Taxa de Engajamento</th>
              <th>Taxa de Conversão</th>
              <th>Custo (Ads)</th>
            </tr>
          </thead>
          <tbody>
            </tbody>
        </table>
      </div>
    </div>

    <div class="card mt-20">
      <h3>Principais Campanhas (UTM)</h3>
      <div class="table-responsive mt-10">
        <table id="campaignTable">
          <thead>
            <tr>
              <th>Campanha</th>
              <th>Sessões</th>
              <th>Usuários</th>
              <th>Conversões</th>
              <th>Receita</th>
            </tr>
          </thead>
          <tbody>
            </tbody>
        </table>
      </div>
    </div>

  </div>

  <style>
    .loading-state {
      padding: 40px;
      text-align: center;
      color: #64748b;
      font-size: 1.1rem;
    }
    .charts-grid {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 20px;
      margin-top: 20px;
    }
    .chart-box {
      position: relative;
      height: 350px;
      padding-bottom: 40px;
    }
    .chart-box h3, .card h3 {
      font-size: 1.1rem;
      color: var(--text-main);
      margin-bottom: 15px;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 10px;
    }
    .mt-10 { margin-top: 10px; }
    .mt-20 { margin-top: 20px; }
  </style>

  <script>
    // Função para formatar as datas de YYYYMMDD para DD/MM
    const formatDate = (dateStr) => {
      const year = dateStr.substring(0, 4);
      const month = dateStr.substring(4, 6);
      const day = dateStr.substring(6, 8);
      return `${day}/${month}`;
    };

    // Cores padronizadas para os gráficos
    const colors = [
      '#3b82f6', '#10b981', '#f59e0b', '#ef4444', 
      '#8b5cf6', '#06b6d4', '#ec4899', '#f97316'
    ];

    async function loadAcquisitionData() {
      try {
        const response = await fetch('/api/admin/analytics/aquisicao.json');
        if (!response.ok) throw new Error('Falha na API');
        const data = await response.json();

        document.getElementById('loading').style.display = 'none';
        document.getElementById('dashboard-content').style.display = 'block';

        renderSourceMediumChart(data.sourceMedium);
        renderTrendsChart(data.trends);
        renderKpiTable(data.kpis);
        renderCampaignTable(data.campaigns);

      } catch (error) {
        document.getElementById('loading').innerHTML = '<p style="color: red;">Erro ao carregar dados. Verifique a configuração da API.</p>';
        console.error(error);
      }
    }

    function renderSourceMediumChart(sourceData) {
      const ctx = document.getElementById('sourceMediumChart');
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: sourceData.map(d => d.label),
          datasets: [{
            data: sourceData.map(d => d.value),
            backgroundColor: colors,
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'right' }
          }
        }
      });
    }

    function renderTrendsChart(trendsData) {
      const ctx = document.getElementById('trendsChart');
      const datasets = trendsData.datasets.map((ds, index) => ({
        label: ds.label,
        data: ds.data,
        borderColor: colors[index % colors.length],
        backgroundColor: colors[index % colors.length] + '20', // Opacidade
        tension: 0.3,
        fill: true
      }));

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: trendsData.dates.map(formatDate),
          datasets: datasets
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            y: { beginAtZero: true }
          }
        }
      });
    }

    function renderKpiTable(kpis) {
      const tbody = document.querySelector('#kpiTable tbody');
      if (kpis.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center">Nenhum dado encontrado</td></tr>';
        return;
      }

      tbody.innerHTML = kpis.map(kpi => `
        <tr>
          <td><strong>${kpi.channel}</strong></td>
          <td>${kpi.engagementRate}%</td>
          <td>${kpi.conversionRate}%</td>
          <td>R$ ${kpi.adCost}</td>
        </tr>
      `).join('');
    }

    function renderCampaignTable(campaigns) {
      const tbody = document.querySelector('#campaignTable tbody');
      
      // Filtra campanhas "(not set)" ou orgânicas genéricas se preferir
      const validCampaigns = campaigns.filter(c => c.campaign !== '(not set)' && c.campaign !== '(direct)');

      if (validCampaigns.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center">Nenhuma campanha UTM ativa no período</td></tr>';
        return;
      }

      tbody.innerHTML = validCampaigns.map(camp => `
        <tr>
          <td><span class="badge badge-success">${camp.campaign}</span></td>
          <td>${camp.sessions.toLocaleString('pt-BR')}</td>
          <td>${camp.users.toLocaleString('pt-BR')}</td>
          <td>${camp.conversions.toLocaleString('pt-BR')}</td>
          <td>R$ ${camp.revenue.replace('.', ',')}</td>
        </tr>
      `).join('');
    }

    // Inicializa a chamada na montagem da página
    document.addEventListener('DOMContentLoaded', loadAcquisitionData);
  </script>
</AnalyticsLayout>