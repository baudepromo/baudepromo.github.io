---
// src/pages/admin-ynSMHVmh/analytics/visao-geral.astro
import AnalyticsLayout from '../../../../layouts/AnalyticsLayout.astro';
const title = 'Visão Geral';
---

<AnalyticsLayout title={title}>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <div class="kpi-grid" id="kpiGrid">
    <p>Carregando indicadores reais do GA4...</p>
  </div>

  <div class="chart-container" style="position: relative; height:40vh; width:100%; margin: 2rem 0;">
    <canvas id="trendChart"></canvas>
  </div>

  <div class="kpi-grid" style="grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2rem;">
    <div>
      <h3>Comparativo (Últimos 30 dias)</h3>
      <table id="compTable">
        <thead>
          <tr><th>Métrica</th><th>Atual</th><th>Anterior</th><th>Var.</th></tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
    <div>
      <h3>Top 5 páginas mais vistas</h3>
      <table id="pagesTable">
        <thead>
          <tr><th>Caminho da Página</th><th>Visualizações</th></tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</AnalyticsLayout>

<script>
  async function initDashboard() {
    try {
      const res = await fetch('/api/admin/analytics/visao-geral.json');
      if (!res.ok) throw new Error('Falha ao buscar dados');
      const data = await res.json();

      // Função auxiliar para definir a seta e cor da tendência
      const getTrendHTML = (trendStr) => {
        const isUp = trendStr.includes('+');
        const icon = isUp ? '↑' : '↓';
        const cssClass = isUp ? 'trend-up' : 'trend-down';
        return `<div class="kpi-trend ${cssClass}">${icon} ${trendStr}</div>`;
      };

      // 1. Preencher KPIs Superiores
      const kpiGrid = document.getElementById('kpiGrid');
      kpiGrid.innerHTML = `
        <div class="kpi-card">
          <div class="kpi-value">${data.kpis.activeUsers.toLocaleString()}</div>
          <div class="kpi-label">Usuários Ativos</div>
          ${getTrendHTML(data.kpis.trends.activeUsers)}
        </div>
        <div class="kpi-card">
          <div class="kpi-value">${data.kpis.sessions.toLocaleString()}</div>
          <div class="kpi-label">Sessões Totais</div>
          ${getTrendHTML(data.kpis.trends.sessions)}
        </div>
        <div class="kpi-card">
          <div class="kpi-value">R$ ${data.kpis.revenue.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</div>
          <div class="kpi-label">Receita (Período)</div>
          ${getTrendHTML(data.kpis.trends.revenue)}
        </div>
        <div class="kpi-card">
          <div class="kpi-value">${data.kpis.conversionRate.toFixed(2)}%</div>
          <div class="kpi-label">Taxa de Conversão</div>
          ${getTrendHTML(data.kpis.trends.conversionRate)}
        </div>
      `;

      // 2. Preencher Tabela Comparativa (Dados já vem formatados da API)
      const compBody = document.querySelector('#compTable tbody');
      compBody.innerHTML = data.comparative.map(item => `
        <tr>
          <td><strong>${item.metric}</strong></td>
          <td>${item.current}</td>
          <td>${item.previous}</td>
          <td class="${item.class}">${item.trend}</td>
        </tr>
      `).join('');

      // 3. Preencher Top Páginas
      const pagesBody = document.querySelector('#pagesTable tbody');
      pagesBody.innerHTML = data.topPages.map(page => `
        <tr>
          <td style="font-family: monospace; font-size: 0.9em;">${page.path}</td>
          <td>${page.views}</td>
        </tr>
      `).join('');

      // 4. Inicializar Gráfico com dados reais dos últimos 10 dias
      const ctx = document.getElementById('trendChart');
      // @ts-ignore
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: data.dailyData.map(d => d.date),
          datasets: [
            { 
              label: 'Usuários Diários', 
              data: data.dailyData.map(d => d.users), 
              borderColor: '#3b82f6', 
              backgroundColor: 'rgba(59, 130, 246, 0.1)',
              fill: true,
              tension: 0.4 
            },
            { 
              label: 'Sessões Diárias', 
              data: data.dailyData.map(d => d.sessions), 
              borderColor: '#10b981', 
              borderDash: [5, 5], // Diferenciar linha de sessões
              tension: 0.4 
            }
          ]
        },
        options: { 
          responsive: true, 
          maintainAspectRatio: false,
          interaction: { intersect: false, mode: 'index' },
          plugins: {
            legend: { position: 'top', align: 'end' }
          },
          scales: {
            y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } },
            x: { grid: { display: false } }
          }
        }
      });

    } catch (error) {
      console.error('Erro no dashboard:', error);
      const kpiGrid = document.getElementById('kpiGrid');
      kpiGrid.innerHTML = `<p style="color: red;">Erro ao carregar dados do Analytics. Verifique o console e as variáveis de ambiente.</p>`;
    }
  }

  window.addEventListener('DOMContentLoaded', initDashboard);
</script>

<style>
  /* Estilos rápidos para garantir a visualização */
  .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .kpi-card { padding: 1.5rem; background: #fff; border: 1px solid #eee; border-radius: 8px; }
  .kpi-value { font-size: 1.5rem; font-weight: bold; }
  .kpi-label { color: #666; font-size: 0.9rem; margin-bottom: 0.5rem; }
  .trend-up { color: #10b981; font-weight: 500; }
  .trend-down { color: #ef4444; font-weight: 500; }
  table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; }
  th, td { padding: 0.75rem; text-align: left; border-bottom: 1px solid #eee; }
  th { background: #f9fafb; font-size: 0.8rem; text-transform: uppercase; color: #666; }
</style>