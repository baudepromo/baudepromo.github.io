---
import AdminLayout from '../../../../layouts/TabelasAdminLayout.astro';
import { supabase } from '../../../../lib/supabase';

const title = "Gerenciar Produtos";

const { data: produtos } = await supabase
  .from('produtos')
  .select('*')
  .order('id', { ascending: false });

const getColumns = (dataArray) => {
  if (!dataArray || dataArray.length === 0) return [];
  // Filtramos colunas que talvez não queiramos mostrar na grade principal para economizar espaço
  return Object.keys(dataArray[0]).filter(col => !['created_at', 'updated_at'].includes(col));
};

const formatValue = (value) => {
  if (value === null || value === undefined) return '-';
  if (typeof value === 'boolean') return value ? '✅' : '❌';
  return String(value);
};

const colunas = getColumns(produtos);
// Calculamos o número de colunas + 1 para a coluna de "Ações"
const gridColumnCount = colunas.length + 1;
---

<AdminLayout title={title}>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <button
      class="btn-novo"
      data-tabela="produtos"
      data-cols={JSON.stringify(colunas)}
    >
      + Novo Produto
    </button>
  </div>

  <div class="grid-container" style={`--num-cols: ${gridColumnCount}`}>
    {produtos && produtos.length > 0 ? (
      <>
        <div class="grid-row grid-header">
          {colunas.map(coluna => <div class="grid-item">{coluna}</div>)}
          <div class="grid-item">Ações</div>
        </div>

        {produtos.map(item => (
          <div class="grid-row">
            {colunas.map(coluna => (
              <div class="grid-item" title={formatValue(item[coluna])}>
                {formatValue(item[coluna])}
              </div>
            ))}
            <div class="grid-item">
              <button
                class="btn-editar"
                data-id={item.id}
                data-tabela="produtos"
                data-item={encodeURIComponent(JSON.stringify(item))}
              >
                Editar
              </button>
            </div>
          </div>
        ))}
      </>
    ) : (
      <div style="padding: 20px; text-align: center;">Nenhum produto cadastrado.</div>
    )}
  </div>
</AdminLayout>

<style>
    .grid-container {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    min-width: fit-content; /* Garante que a grade não esmague em telas pequenas */
  }

  .grid-row {
    display: grid;
    /* Aqui está o segredo: dividimos o espaço proporcionalmente */
    /* Você pode trocar '1fr' por larguras fixas como '100px' se preferir */
    grid-template-columns: repeat(var(--num-cols), minmax(120px, 1fr));
    gap: 15px;
    padding: 12px 20px;
    border-bottom: 1px solid #f1f5f9;
    align-items: center;
  }

  .grid-header {
    background-color: #f8fafc;
    font-weight: bold;
    color: #475569;
    text-transform: uppercase;
    font-size: 0.75rem;
    position: sticky;
    top: 0;
  }

  .grid-item {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-size: 0.9rem;
  }

  .grid-row:hover:not(.grid-header) {
    background-color: #f8fafc;
  }
</style>