<script type="module">
    // 1. Importações unificadas (removi a importação duplicada)
    import { 
        auth, 
        db, 
        onAuthStateChanged, 
        doc, 
        getDoc, 
        updateDoc, 
        arrayRemove 
    } from '/src/lib/firebase/client';
    
    import { supabase } from '/src/lib/supabase';

    let currentUser = null;

    onAuthStateChanged(auth, async (user) => {
        const grid = document.getElementById("fav-grid");
        
        // Proteção extra: se não achar o grid na DOM, não faz nada
        if (!grid) return;

        currentUser = user;

        if (user) {
            await loadUserFavorites(user.uid);
        } else {
            renderLoginState(grid);
        }
    });

    async function loadUserFavorites(uid) {
        const grid = document.getElementById("fav-grid");
        try {
            const userDocRef = doc(db, "wishlists", uid); 
            const userSnap = await getDoc(userDocRef);

            // Verifica se o documento existe e se a propriedade items está lá
            if (!userSnap.exists() || !userSnap.data().items) {
                renderEmptyState(grid);
                return;
            }

            const favoriteIds = userSnap.data().items;

            // 2. Correção Crítica: Verifica se o array está vazio antes de chamar o Supabase
            if (favoriteIds.length === 0) {
                renderEmptyState(grid);
                return;
            }

            const { data: myFavorites, error } = await supabase
                .from('produtos')
                .select('*')
                .in('id', favoriteIds);

            if (error) throw error;
            renderGrid(grid, myFavorites);

        } catch (error) {
            console.error("Erro detalhado ao carregar favoritos:", error);
            grid.innerHTML = `<p style="color: red; text-align: center;">Erro ao carregar favoritos. Tente novamente mais tarde.</p>`;
        }
    }

    window.removeFavorite = async (productId) => {
        if (!currentUser) return;
        if (!confirm("Remover dos favoritos?")) return;

        const card = document.getElementById(`card-${productId}`);
        
        try {
            if(card) card.style.opacity = '0.5';
            const userDocRef = doc(db, "wishlists", currentUser.uid);

            await updateDoc(userDocRef, {
                items: arrayRemove(productId)
            });

            if(card) card.remove();
            
            const grid = document.getElementById("fav-grid");
            if (grid.children.length === 0) renderEmptyState(grid);

        } catch (error) {
            console.error("Erro ao remover:", error);
            if(card) card.style.opacity = '1';
            alert("Não foi possível remover o item.");
        }
    };

    function renderGrid(grid, products) {
        grid.innerHTML = "";
        products.forEach(p => {
            
            grid.innerHTML += `
                <div class="card" id="card-${p.id}">
                    <button class="btn-remove-fav" onclick="window.removeFavorite('${p.id}')">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                    <img src="${p.img}" alt="${p.title}">
                    <div class="card-content">
                        <h3>${p.title}</h3>
                        <span class="price">R$ ${p.price}</span>
                        <a href="/${p.slug}/p/${p.id}" class="pill-btn btn-details">Ver Oferta</a>
                    </div>
                </div>`;
        });
    }

    function renderEmptyState(grid) {
        grid.innerHTML = `<div class="empty-state"><h2>Sua lista está vazia</h2><a href="/produtos" class="pill-btn btn-cta">Ver Ofertas</a></div>`;
    }

    function renderLoginState(grid) {
        grid.innerHTML = `<div class="empty-state"><h2>Acesso Restrito</h2><p>Faça login para ver favoritos.</p></div>`;
    }
</script>